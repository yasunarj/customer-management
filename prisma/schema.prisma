generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id           Int           @id @default(autoincrement())
  name         String
  phone        String?
  reservations Reservation[]
}

model Reservation {
  id              Int       @id @default(autoincrement())
  productName     String
  price           Int
  reservationDate DateTime
  deliveryDate    DateTime?
  customerId      Int
  type            String
  customer        Customer  @relation(fields: [customerId], references: [id])
}

model SafeCheck {
  id       Int      @id @default(autoincrement())
  date     DateTime @unique
  bara     Int
  yen10000 Int
  yen5000  Int
  yen1000  Int
  yen500   Int
  yen100   Int
  yen50    Int
  yen10    Int
  yen5     Int
  yen1     Int
  total    Int
  createAt DateTime @default(now())
  updateAt DateTime @updatedAt
}

model ProductExpiry {
  id          Int      @id @default(autoincrement())
  gondolaNo   Int
  category    String
  productName String
  expiryDate  DateTime @db.Date
  quantity    Int      @default(1)
  manager     String
  createdAt   DateTime @default(now())
  updateAt    DateTime @updatedAt

  @@index([expiryDate])
  @@map("product_expiry")
}

model DailyTask {
  id        String   @id @default(cuid())
  ownerId   String
  title     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  onMon     Boolean  @default(true)
  onTue     Boolean  @default(true)
  onWed     Boolean  @default(true)
  onThu     Boolean  @default(true)
  onFri     Boolean  @default(true)
  onSat     Boolean  @default(true)
  onSun     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checks DailyTaskCheck[]

  @@unique([ownerId, title])
  @@index([ownerId])
  @@index([ownerId, isActive])
}

model DailyTaskCheck {
  id        String    @id @default(cuid())
  ownerId   String
  date      String // "YYYY-MM-DD"（JST）
  taskId    String
  task      DailyTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  checkedBy String?
  checkedAt DateTime  @default(now())

  @@unique([ownerId, date, taskId])
  @@index([ownerId, date])
  @@index([taskId])
}

model OwnerGateLimit {
  key         String    @id
  failCount   Int       @default(0)
  lockedUntil DateTime?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  @@index([lockedUntil])
  @@map("owner_gate_limits")
}

enum TrainingCategory {
  REGISTER
  CLEANING
  PRODUCT_MANAGEMENT
  OTHER
}

model Store {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees TrainingEmployee[]
  workItems TrainingWorkItem[]
}

model TrainingEmployee {
  id        String    @id @default(cuid())
  storeId   String
  name      String
  joinedAt  DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  store       Store                @relation(fields: [storeId], references: [id])
  assignments TrainingAssignment[]

  @@index([storeId])
  @@index([storeId, isActive])
}

model TrainingWorkItem {
  id          String           @id @default(cuid())
  storeId     String
  title       String
  category    TrainingCategory
  description String?
  sortOrder   Int              @default(0)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  store       Store                @relation(fields: [storeId], references: [id])
  assignments TrainingAssignment[]

  @@unique([storeId, title])
  @@index([storeId])
  @@index([storeId, category])
  @@index([storeId, isActive])
}

model TrainingAssignment {
  id          String    @id @default(cuid())
  employeeId  String
  workItemId  String
  assignedAt  DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee TrainingEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  workItem TrainingWorkItem @relation(fields: [workItemId], references: [id])

  checks TrainingCheck[]

  @@unique([employeeId, workItemId])
  @@index([employeeId])
  @@index([workItemId])
}

model TrainingCheck {
  id           String   @id @default(cuid())
  assignmentId String
  checkNumber  Int
  trainerId    String
  trainerName  String?
  comment      String?
  checkedAt    DateTime @default(now())
  createdAt    DateTime @default(now())

  assignment TrainingAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, checkNumber])
  @@index([assignmentId])
  @@index([trainerId])
}
